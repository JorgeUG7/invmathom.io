<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inversa Matriz Homogénea 4x4</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 1200px;
            width: 100%;
            padding: 40px;
            overflow-y: auto;
            max-height: 90vh;
        }

        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 1em;
        }

        .content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 30px;
        }

        @media (max-width: 900px) {
            .content {
                grid-template-columns: 1fr;
            }
        }

        .section {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 10px;
            border-left: 5px solid #667eea;
        }

        .section h2 {
            color: #667eea;
            margin-bottom: 20px;
            font-size: 1.3em;
        }

        .matrix-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin-bottom: 20px;
        }

        .matrix-input {
            width: 100%;
            padding: 10px;
            border: 2px solid #ddd;
            border-radius: 5px;
            font-size: 0.9em;
            text-align: center;
            transition: border-color 0.3s;
        }

        .matrix-input:focus {
            outline: none;
            border-color: #667eea;
            background-color: #f0f4ff;
        }

        .matrix-label {
            grid-column: 1 / -1;
            font-weight: bold;
            color: #333;
            margin-top: 10px;
            text-align: center;
        }

        button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1.1em;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            margin-top: 15px;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
        }

        button:active {
            transform: translateY(0);
        }

        .result-matrix {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin-top: 20px;
            background: white;
            padding: 15px;
            border-radius: 8px;
        }

        .result-cell {
            padding: 12px;
            background: #f0f4ff;
            border: 1px solid #ddd;
            text-align: center;
            border-radius: 5px;
            font-family: 'Courier New', monospace;
            word-break: break-all;
            font-size: 0.85em;
        }

        .formula-box {
            background: white;
            padding: 20px;
            border-radius: 8px;
            margin-top: 20px;
            border-left: 4px solid #764ba2;
        }

        .formula-box h3 {
            color: #764ba2;
            margin-bottom: 10px;
        }

        .formula-box p {
            color: #555;
            line-height: 1.6;
            font-size: 0.95em;
            margin-bottom: 10px;
        }

        .formula-code {
            background: #f5f5f5;
            padding: 10px;
            border-radius: 5px;
            font-family: 'Courier New', monospace;
            overflow-x: auto;
            color: #333;
            font-size: 0.9em;
            margin: 10px 0;
        }

        .error-message {
            background: #fee;
            color: #c33;
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
            border-left: 4px solid #c33;
            display: none;
        }

        .success-message {
            background: #efe;
            color: #3c3;
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
            border-left: 4px solid #3c3;
            display: none;
        }

        .button-group {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .button-group button {
            flex: 1;
        }

        .secondary-btn {
            background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
        }

        .small-btn {
            padding: 8px;
            font-size: 0.9em;
        }

        .info-box {
            background: #e7f3ff;
            border-left: 4px solid #2196F3;
            padding: 15px;
            border-radius: 5px;
            margin-top: 15px;
            color: #0c5aa0;
            font-size: 0.95em;
            line-height: 1.5;
        }

        .determinant-display {
            background: white;
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
            text-align: center;
            font-size: 1.1em;
        }

        .det-label {
            color: #666;
            font-size: 0.9em;
        }

        .det-value {
            color: #667eea;
            font-weight: bold;
            font-family: 'Courier New', monospace;
            font-size: 1.3em;
            margin-top: 5px;
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #eee;
        }

        .tab-button {
            padding: 10px 20px;
            background: none;
            border: none;
            color: #999;
            font-weight: bold;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
            transition: all 0.3s;
        }

        .tab-button.active {
            color: #667eea;
            border-bottom-color: #667eea;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🔢 Inversa de Matriz Homogénea</h1>
        <p class="subtitle">Matriz de transformación 4x4 (Robótica)</p>

        <div class="tabs">
            <button class="tab-button active" onclick="switchTab('calculator')">Calculadora</button>
            <button class="tab-button" onclick="switchTab('theory')">Teoría</button>
        </div>

        <!-- CALCULADORA -->
        <div id="calculator" class="tab-content active">
            <div class="content">
                <!-- INPUT -->
                <div class="section">
                    <h2>📥 Matriz de Entrada (T)</h2>
                    <p style="color: #666; margin-bottom: 15px; font-size: 0.9em;">
                        Ingresa los valores de tu matriz 4x4
                    </p>
                    <div class="matrix-grid" id="inputMatrix"></div>
                    
                    <div class="error-message" id="errorMsg"></div>
                    <div class="success-message" id="successMsg"></div>

                    <button onclick="calculateInverse()">Calcular Inversa</button>
                    <button class="secondary-btn" onclick="loadIdentity()">Cargar Identidad</button>
                    <button class="secondary-btn" onclick="loadExample()">Cargar Ejemplo</button>
                    <button class="secondary-btn" onclick="clearMatrix()">Limpiar</button>
                </div>

                <!-- OUTPUT -->
                <div class="section">
                    <h2>📤 Inversa (T⁻¹)</h2>
                    <div class="result-matrix" id="outputMatrix"></div>
                    
                    <div class="determinant-display" id="detDisplay" style="display:none;">
                        <div class="det-label">Determinante de T:</div>
                        <div class="det-value" id="detValue">0</div>
                    </div>

                    <div class="info-box" style="display:none;" id="infoBox">
                        ✓ Matriz invertible y resultados calculados correctamente
                    </div>

                    <button class="secondary-btn small-btn" onclick="copyToClipboard()" style="margin-top: 15px;">📋 Copiar Resultado</button>
                    <button class="secondary-btn small-btn" onclick="downloadAsCSV()">⬇️ Descargar CSV</button>
                </div>
            </div>
        </div>

        <!-- TEORÍA -->
        <div id="theory" class="tab-content">
            <div class="section">
                <h2>📚 Teoría: Inversa de Matriz Homogénea</h2>
                
                <div class="formula-box">
                    <h3>Definición</h3>
                    <p>Una matriz de transformación homogénea T es una matriz 4×4 que representa la posición y orientación de un objeto en el espacio 3D:</p>
                    <div class="formula-code">
┌       ┐
│ R  p │
│ 0  1 │
└       ┘

donde:
- R = Matriz de rotación 3×3
- p = Vector de posición (3×1)
- 0 = Vector cero (1×3)
- 1 = Escalar
                    </div>
                </div>

                <div class="formula-box">
                    <h3>Fórmula de Inversa</h3>
                    <p>Para una matriz de transformación homogénea T, su inversa T⁻¹ se calcula como:</p>
                    <div class="formula-code">
T⁻¹ = ┌        T  ┐
      │ R   -R·p │
      │ 0    1   │
      └          ┘

donde:
- R^T = Transpuesta de la matriz de rotación
- p = Vector de posición original
                    </div>
                </div>

                <div class="formula-box">
                    <h3>Propiedades Importantes</h3>
                    <p>✓ <strong>T · T⁻¹ = I</strong> (matriz identidad)</p>
                    <p>✓ <strong>T⁻¹ · T = I</strong> (conmutativa para este caso)</p>
                    <p>✓ La matriz R debe ser ortogonal (R^T · R = I)</p>
                    <p>✓ El determinante de T debe ser diferente de cero</p>
                </div>

                <div class="formula-box">
                    <h3>Aplicación en Robótica</h3>
                    <p>La inversa de una matriz de transformación es fundamental para:</p>
                    <ul style="margin-left: 20px; color: #555; line-height: 1.8;">
                        <li>✓ Cinemática inversa de robots manipuladores</li>
                        <li>✓ Transformación de sistemas de coordenadas</li>
                        <li>✓ Cálculo de movimientos relativos</li>
                        <li>✓ Control de actuadores y servomotores</li>
                        <li>✓ Visión por computadora y sensores de posición</li>
                    </ul>
                </div>

                <div class="info-box">
                    <strong>💡 Consejo:</strong> Si tu matriz de rotación tiene columnas con magnitud diferente a 1, o si el determinante está cerca de 0, podría haber errores de redondeo. Verifica que tu matriz de rotación sea ortonormal.
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/11.11.0/math.min.js"></script>
    <script>
        // Crear grid de inputs
        function initializeMatrix() {
            const container = document.getElementById('inputMatrix');
            container.innerHTML = '';
            for (let i = 0; i < 4; i++) {
                for (let j = 0; j < 4; j++) {
                    const input = document.createElement('input');
                    input.type = 'number';
                    input.className = 'matrix-input';
                    input.id = `input_${i}_${j}`;
                    input.placeholder = `[${i},${j}]`;
                    input.step = '0.01';
                    input.value = (i === j) ? '1' : '0';
                    container.appendChild(input);
                }
            }
        }

        // Obtener matriz de inputs
        function getInputMatrix() {
            const matrix = [];
            for (let i = 0; i < 4; i++) {
                const row = [];
                for (let j = 0; j < 4; j++) {
                    const val = parseFloat(document.getElementById(`input_${i}_${j}`).value) || 0;
                    row.push(val);
                }
                matrix.push(row);
            }
            return matrix;
        }

        // Mostrar matriz de salida
        function displayMatrix(matrix, containerId = 'outputMatrix') {
            const container = document.getElementById(containerId);
            container.innerHTML = '';
            for (let i = 0; i < 4; i++) {
                for (let j = 0; j < 4; j++) {
                    const cell = document.createElement('div');
                    cell.className = 'result-cell';
                    let value = matrix[i][j];
                    
                    // Redondear a 6 decimales
                    if (typeof value === 'number') {
                        value = parseFloat(value.toFixed(6));
                    }
                    
                    // Mostrar en notación científica si es muy pequeño
                    if (Math.abs(value) < 0.0001 && value !== 0) {
                        cell.textContent = value.toExponential(2);
                    } else {
                        cell.textContent = value;
                    }
                    
                    container.appendChild(cell);
                }
            }
        }

        // Calcular inversa
        function calculateInverse() {
            const errorMsg = document.getElementById('errorMsg');
            const successMsg = document.getElementById('successMsg');
            errorMsg.style.display = 'none';
            successMsg.style.display = 'none';

            try {
                const T = getInputMatrix();
                
                // Calcular determinante
                const det = math.det(T);
                document.getElementById('detValue').textContent = det.toFixed(6);
                document.getElementById('detDisplay').style.display = 'block';
                
                if (Math.abs(det) < 1e-10) {
                    throw new Error('Determinante cercano a cero. Matriz no invertible.');
                }

                // Calcular inversa usando math.js
                const T_inv = math.inv(T);
                
                // Mostrar resultado
                displayMatrix(T_inv, 'outputMatrix');
                
                successMsg.textContent = '✓ Inversa calculada correctamente';
                successMsg.style.display = 'block';
                document.getElementById('infoBox').style.display = 'block';

            } catch (error) {
                errorMsg.textContent = '❌ Error: ' + error.message;
                errorMsg.style.display = 'block';
                document.getElementById('infoBox').style.display = 'none';
            }
        }

        // Cargar matriz identidad
        function loadIdentity() {
            for (let i = 0; i < 4; i++) {
                for (let j = 0; j < 4; j++) {
                    document.getElementById(`input_${i}_${j}`).value = (i === j) ? '1' : '0';
                }
            }
        }

        // Cargar ejemplo
        function loadExample() {
            const example = [
                [0.866, -0.5, 0, 10],
                [0.5, 0.866, 0, 20],
                [0, 0, 1, 5],
                [0, 0, 0, 1]
            ];
            
            for (let i = 0; i < 4; i++) {
                for (let j = 0; j < 4; j++) {
                    document.getElementById(`input_${i}_${j}`).value = example[i][j];
                }
            }
        }

        // Limpiar matriz
        function clearMatrix() {
            loadIdentity();
            document.getElementById('outputMatrix').innerHTML = '';
            document.getElementById('errorMsg').style.display = 'none';
            document.getElementById('successMsg').style.display = 'none';
            document.getElementById('detDisplay').style.display = 'none';
        }

        // Copiar al portapapeles
        function copyToClipboard() {
            const cells = document.querySelectorAll('#outputMatrix .result-cell');
            if (cells.length === 0) {
                alert('Primero calcula la inversa');
                return;
            }

            let text = '';
            for (let i = 0; i < 4; i++) {
                for (let j = 0; j < 4; j++) {
                    text += cells[i * 4 + j].textContent + '\t';
                }
                text += '\n';
            }

            navigator.clipboard.writeText(text).then(() => {
                alert('✓ Matriz copiada al portapapeles');
            });
        }

        // Descargar como CSV
        function downloadAsCSV() {
            const cells = document.querySelectorAll('#outputMatrix .result-cell');
            if (cells.length === 0) {
                alert('Primero calcula la inversa');
                return;
            }

            let csv = '';
            for (let i = 0; i < 4; i++) {
                for (let j = 0; j < 4; j++) {
                    csv += cells[i * 4 + j].textContent;
                    if (j < 3) csv += ',';
                }
                csv += '\n';
            }

            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'matriz_inversa.csv';
            a.click();
        }

        // Cambiar tabs
        function switchTab(tabName) {
            // Ocultar todos los tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });

            // Mostrar tab seleccionado
            document.getElementById(tabName).classList.add('active');
            event.target.classList.add('active');
        }

        // Inicializar al cargar
        window.onload = function() {
            initializeMatrix();
        };
    </script>
</body>
</html>
